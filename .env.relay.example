# Public relay service. Terminate TLS at the platform/reverse proxy and expose
# /v1/oauth/token, /v1/device and /v1/activity through HTTPS/WSS.
RELAY_HOST=127.0.0.1
RELAY_PORT=8790

# Exact Activity origin, comma separated when multiple deployments exist.
RELAY_ACTIVITY_ORIGINS=https://activity.example.com

# installation ID -> outbound device token. Generate with npm run admin:provision.
RELAY_DEVICES_JSON={"installation-uuid":"replace-with-32-byte-random-token"}

RELAY_DISCORD_CLIENT_ID=
RELAY_DISCORD_CLIENT_SECRET=
# Usually omitted for an Activity authorization-code exchange. Set only when
# the Discord application OAuth configuration requires the exact redirect URI.
RELAY_OAUTH_REDIRECT_URI=

RELAY_OAUTH_SESSION_TTL_MS=120000
RELAY_ACTIVITY_SESSION_TTL_MS=300000
RELAY_MAX_PAYLOAD_BYTES=1000000
RELAY_MAX_MESSAGES_PER_MINUTE=180
