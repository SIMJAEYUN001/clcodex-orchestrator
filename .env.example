DISCORD_GUILD_ID=
DISCORD_FORUM_CHANNEL_ID=
DISCORD_ORCHESTRATOR_BOT_TOKEN=

RUNTIME_ROOT=.runtime
HARNESS_ROOT=.harness
DATABASE_PATH=.runtime/state.sqlite
PROVIDER_SECRET_FILE_ROOT=.runtime/external-secrets

# 32 bytes encoded as base64/base64url/hex. If omitted, a mode-0600 key is generated.
PROVIDER_VAULT_MASTER_KEY=

# Exact names or wildcard suffixes. Private, non-loopback endpoints must be explicit.
PROXY_ALLOWED_HOSTS=
ALLOW_LOOPBACK_PROXY=true
ALLOW_INSECURE_LOOPBACK_PROXY=true
PROVIDER_REQUEST_TIMEOUT_MS=12000
