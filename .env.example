DISCORD_GUILD_ID=
DISCORD_FORUM_CHANNEL_ID=

# 네 역할은 반드시 서로 다른 Discord Application/Bot token을 사용합니다.
DISCORD_ORCHESTRATOR_BOT_TOKEN=
DISCORD_BACKEND_BOT_TOKEN=
DISCORD_FRONTEND_BOT_TOKEN=
DISCORD_REVIEWER_BOT_TOKEN=

RUNTIME_ROOT=.runtime
PROJECTS_ROOT=.runtime/projects
HARNESS_ROOT=.harness
DATABASE_PATH=.runtime/state.sqlite
PROVIDER_SECRET_FILE_ROOT=.runtime/external-secrets
DISCORD_OUTPUT_FLUSH_INTERVAL_MS=1500

# 32 bytes encoded as base64/base64url/hex. If omitted, a mode-0600 key is generated.
PROVIDER_VAULT_MASTER_KEY=

# Exact names or wildcard suffixes. Private, non-loopback endpoints must be explicit.
PROXY_ALLOWED_HOSTS=
ALLOW_LOOPBACK_PROXY=true
ALLOW_INSECURE_LOOPBACK_PROXY=true
PROVIDER_REQUEST_TIMEOUT_MS=12000

# Upstream credential은 이 loopback gateway 안에서만 복원됩니다.
PROVIDER_GATEWAY_HOST=127.0.0.1
PROVIDER_GATEWAY_PORT=0
PROVIDER_GATEWAY_ROUTE_TTL_MS=86400000

# 권장 기본값. /admin은 Discord Activity를 직접 실행하고, 이 프로세스는
# relay로 outbound WSS 연결만 생성합니다. 외부 inbound 관리 HTTP 포트는 없습니다.
ADMIN_UI_MODE=activity-relay
ADMIN_RELAY_WS_URL=wss://relay.example.com
ADMIN_RELAY_INSTALLATION_ID=
ADMIN_RELAY_DEVICE_TOKEN=
ADMIN_RELAY_DEVICE_KEY_PATH=.runtime/admin-relay/device-signing-private.jwk
ADMIN_RELAY_STARTUP_TIMEOUT_MS=15000
ADMIN_RELAY_RECONNECT_MIN_MS=1000
ADMIN_RELAY_RECONNECT_MAX_MS=30000
ADMIN_RELAY_MAX_PAYLOAD_BYTES=1000000
ADMIN_GRANT_TTL_MS=60000
ADMIN_SESSION_TTL_MS=300000

# 명시적으로 ADMIN_UI_MODE=legacy-loopback을 선택한 경우에만 사용합니다.
# 이 모드는 외부 공개용이 아니며 127.0.0.1에만 바인딩해야 합니다.
ADMIN_SETUP_HOST=127.0.0.1
ADMIN_SETUP_PORT=8787
ADMIN_SETUP_PUBLIC_URL=
ADMIN_SETUP_SESSION_TTL_MS=600000
ADMIN_FRAME_ANCESTORS='none'

# Agent structured command tool endpoint.
COMMAND_TOOL_HOST=127.0.0.1
COMMAND_TOOL_PORT=0

# JSON string arrays. Empty TASK_COMMAND_PREFIXES uses the built-in safe allowlist.
SPEC_VERIFICATION_COMMANDS=[]
TASK_COMMAND_PREFIXES=[]
SPEC_AUTO_PUSH=false
